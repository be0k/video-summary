# Optional path overrides for the local web app.
#
# Defaults assume this repository layout:
#   .
#   ├── lingbot-map/
#   ├── Trimamba/
#   ├── merging/
#   └── video_retrieval/

DRONE_PROJECT_ROOT=/path/to/graduate_project
CONDA_ROOT=/path/to/miniconda3

# Python interpreters. Leave unset when CONDA_ROOT has these env names.
LINGBOT_PYTHON=/path/to/miniconda3/envs/lingbot-map/bin/python
TRIMAMBA_PYTHON=/path/to/miniconda3/envs/triple/bin/python
RETRIEVAL_PYTHON=/path/to/miniconda3/envs/retrieval/bin/python

# Required model files.
LINGBOT_MODEL_PATH=/path/to/lingbot-map-long.pt
TRIMAMBA_CKPT=/path/to/Trimamba/checkpoints/best_model_ckpt.pth

# Optional storage override for uploaded videos and job outputs.
MERGING_DATA_ROOT=/path/to/jobs
